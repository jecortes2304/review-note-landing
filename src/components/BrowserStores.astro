---
interface Props {
  label?: string;
  size?: 'sm' | 'md';
}
const { label = 'Available on', size = 'md' } = Astro.props;

const stores = [
  {
    name: 'Chrome',
    url: 'https://chromewebstore.google.com/detail/note-reviewer/fmfahaplknplobmakjodeiajiaaipooo',
    soon: false,
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="4" fill="#4285F4"/>
      <path d="M12 8h8.66A10 10 0 1 0 12 22V16a4 4 0 0 1 0-8Z" fill="#34A853" clip-path="url(#bot)"/>
      <path d="M12 8H3.34A10 10 0 0 0 12 22V16a4 4 0 0 1-4-4 4 4 0 0 1 .69-2.25L12 8Z" fill="#FBBC05"/>
      <path d="M12 8h8.66A10 10 0 0 0 3.34 8H12Z" fill="#EA4335"/>
    </svg>`,
  },
  {
    name: 'Edge',
    url: 'https://chromewebstore.google.com/detail/note-reviewer/fmfahaplknplobmakjodeiajiaaipooo',
    soon: false,
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21 12.5C21 17.747 16.971 22 12 22c-1.79 0-3.46-.51-4.876-1.392C8.5 21 10 21.5 12 21.5c4.142 0 7-3.358 7-7.5 0-2.5-1.5-4.5-3.5-5.5 2.5.5 5.5 2.5 5.5 4Z" fill="#0078D7"/>
      <path d="M3.5 15A8.5 8.5 0 1 1 17.4 8.6C16.1 7.6 14.1 7 12 7c-3.3 0-6 2.2-6 5.5 0 1.9.9 3.4 2.3 4.4-2-.6-3.5-2-4.8-1.9Z" fill="#0078D7" opacity=".6"/>
      <path d="M12 22c2 0 3.5-.5 4.876-1.392A8.5 8.5 0 0 0 7.3 16.9c.5.4 1.1.8 1.7 1.1A6 6 0 0 0 12 19c2.5 0 4-1 5-2-1 2.5-3 5-5 5Z" fill="#34AADC"/>
    </svg>`,
  },
  {
    name: 'Firefox',
    url: 'https://addons.mozilla.org/es-ES/firefox/addon/note-reviewer/?utm_source=addons.mozilla.org&utm_medium=referral&utm_content=search',
    soon: false,
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21.5 12A9.5 9.5 0 1 1 12 2.5c1.2 0 2.3.2 3.4.6-1-.3-2.2-.1-3 .6C9.5 6 9 9 11 11c.8.8 1.8 1.1 2.8 1 1.8-.2 3.2-1.6 3.2-3.5 0-.7-.2-1.3-.5-1.9C18.3 7.8 20 9.8 20 12c0 4.4-3.6 8-8 8s-8-3.6-8-8c0-2.4 1.1-4.6 2.8-6.1A9.5 9.5 0 0 0 21.5 12Z" fill="#FF7139"/>
      <path d="M15.2 3.1C13.8 5 12.7 8 14 10.5c.4.8 1 1.4 1.8 1.7-1 .7-2.2.9-3.3.5-2.2-.8-3.1-3.4-1.8-5.3.5-.8 1.3-1.3 2.1-1.5.9-.2 1.8 0 2.4-.8Z" fill="#FF980E"/>
    </svg>`,
  },
  {
    name: 'Safari',
    url: 'https://apps.apple.com/us/genre/ios-utilities/id6015',
    soon: true,
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="10" fill="url(#safari-bg)"/>
      <defs>
        <linearGradient id="safari-bg" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#1C8EF9"/>
          <stop offset="100%" stop-color="#07C8F9"/>
        </linearGradient>
      </defs>
      <polygon points="12,5 13.5,10.5 19,12 13.5,13.5 12,19 10.5,13.5 5,12 10.5,10.5" fill="white" opacity="0.9"/>
    </svg>`,
  },
];

const btnBase = size === 'sm'
  ? 'flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all border'
  : 'flex items-center gap-3 px-5 py-3.5 rounded-xl text-sm font-semibold transition-all border';

const iconSize = size === 'sm' ? 'w-4 h-4' : 'w-5 h-5';
---

<div class="w-full">
  {label && (
    <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-400 mb-5">{label}</p>
  )}
  <div class="flex flex-wrap justify-center gap-3">
    {stores.map(({ name, url, soon, icon }) => (
      soon ? (
        <span
          class:list={[btnBase, 'bg-slate-100 text-slate-400 border-slate-200 cursor-default select-none']}
          title={`${name} — Coming Soon`}
        >
          <span class={iconSize} set:html={icon} />
          {name}
          <span class="text-[10px] font-bold uppercase tracking-wider bg-slate-200 text-slate-500 px-1.5 py-0.5 rounded-md leading-none">Soon</span>
        </span>
      ) : (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={[btnBase, 'bg-white text-slate-700 border-slate-200 hover:border-brand-700 hover:text-brand-700 hover:shadow-sm']}
        >
          <span class={iconSize} set:html={icon} />
          {name}
          <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      )
    ))}
  </div>
</div>

