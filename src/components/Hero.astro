---
import BrowserStores from './BrowserStores.astro';
---

<section class="relative overflow-hidden bg-linear-to-br from-brand-700 via-brand-600 to-brand-500 text-white">
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-36 text-center">
    <span class="inline-flex items-center gap-2 bg-white/15 border border-white/25 text-white/90 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-8">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      Browser Extension · AI-Powered
    </span>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6 max-w-4xl mx-auto">
      Note Reviewer:<br />
      <span class="text-sky-300">AI-Powered Quality &amp; Compliance</span><br />
      for ABA Notes
    </h1>

    <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-12 leading-relaxed">
      Real-time clinical note review right inside your browser's side panel. Designed for BCBAs who need
      instant quality feedback — without ever modifying the original text.
    </p>

    <div id="install" class="bg-white/10 border border-white/20 rounded-2xl px-8 py-7 max-w-xl mx-auto mb-8 backdrop-blur-sm">
      <BrowserStores label="Install on your browser" size="md" />
    </div>

    <div class="flex justify-center gap-6">
      <a
        href="#how-it-works"
        class="inline-flex items-center gap-2 text-white/70 hover:text-white text-sm font-medium transition-colors"
      >
        See how it works
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>

    <p class="mt-8 text-white/50 text-sm">Trusted by ABA professionals · No PHI stored · Works on any EHR</p>
  </div>
</section>
