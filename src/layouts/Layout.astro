---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Note Reviewer – AI-Powered Quality & Compliance for ABA Notes',
  description = 'Note Reviewer is a Chrome extension that uses AI to review clinical notes in real time for BCBAs and RBTs, ensuring quality and ABA compliance without modifying the original text.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="uP26RqNpEKFqTItC6mKWAc_v5jGmQZPHfNNTnoPuqRA" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white font-sans text-slate-800 antialiased">
    <slot />
  </body>
</html>


