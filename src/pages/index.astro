---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ─────────────────────────────────────────────────────────
       NAVBAR
  ───────────────────────────────────────────────────────────── -->
  <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 group">
        <img src="/favicon.svg" alt="Note Reviewer Logo" class="w-6 h-6 group-hover:animate-spin-slow transition-transform" />
        <span class="font-semibold text-slate-900 text-sm tracking-tight">Note Reviewer</span>
      </a>
      <!-- Nav links -->
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
        <a href="#features" class="hover:text-brand-700 transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-brand-700 transition-colors">How it Works</a>
        <a href="#privacy" class="hover:text-brand-700 transition-colors">Privacy</a>
        <a href="#contact" class="hover:text-brand-700 transition-colors">Contact</a>
      </nav>
      <!-- CTA -->
      <a
        href="https://chromewebstore.google.com"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-brand-700 hover:bg-brand-800 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm"
      >
        Get Started
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </header>

  <!-- ─────────────────────────────────────────────────────────
       HERO
  ───────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-linear-to-br from-brand-700 via-brand-600 to-brand-500 text-white">
    <!-- subtle grid pattern -->
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 28px 28px;">
    </div>

    <div class="relative max-w-6xl mx-auto px-6 py-28 md:py-36 text-center">
      <!-- Badge -->
      <span class="inline-flex items-center gap-2 bg-white/15 border border-white/25 text-white/90 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-8">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        Chrome Extension · AI-Powered
      </span>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6 max-w-4xl mx-auto">
        Note Reviewer:<br />
        <span class="text-sky-300">AI-Powered Quality &amp; Compliance</span><br />
        for ABA Notes
      </h1>

      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
        Real-time clinical note review in your browser's side panel. Designed for BCBAs and RBTs who need
        instant quality feedback — without ever modifying the original text.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://chromewebstore.google.com"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-white text-brand-700 font-bold text-base px-8 py-4 rounded-xl hover:bg-sky-50 transition-colors shadow-lg"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
          Get Started — It's Free
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center justify-center gap-2 border border-white/40 text-white font-semibold text-base px-8 py-4 rounded-xl hover:bg-white/10 transition-colors"
        >
          See How it Works
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>

      <!-- Social proof -->
      <p class="mt-10 text-white/50 text-sm">Trusted by ABA professionals · No PHI stored · Works on any EHR</p>
    </div>
  </section>

  <!-- ─────────────────────────────────────────────────────────
       FEATURES
  ───────────────────────────────────────────────────────────── -->
  <section id="features" class="py-24 bg-slate-50">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Section header -->
      <div class="text-center mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-700">Features</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
          Everything you need to write<br class="hidden md:block" /> better clinical notes
        </h2>
        <p class="mt-4 text-slate-500 max-w-xl mx-auto text-lg">
          Note Reviewer sits quietly in your browser and gives you expert-level feedback in real time.
        </p>
      </div>

      <!-- Grid 3 cols -->
      <div class="grid md:grid-cols-3 gap-8">

        <!-- Feature 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md transition-shadow group">
          <div class="w-12 h-12 rounded-xl bg-brand-700/10 flex items-center justify-center mb-6 group-hover:bg-brand-700 transition-colors">
            <svg class="w-6 h-6 text-brand-700 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Smart Sidebar</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Clinical suggestions appear in Chrome's native side panel — right next to your work, without interrupting your documentation flow or altering the source text.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md transition-shadow group">
          <div class="w-12 h-12 rounded-xl bg-brand-700/10 flex items-center justify-center mb-6 group-hover:bg-brand-700 transition-colors">
            <svg class="w-6 h-6 text-brand-700 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Clinical Precision</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            AI trained on ABA compliance standards and best practices. Get targeted feedback on objectivity, measurability, and regulatory requirements specific to behavior analysis.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 hover:shadow-md transition-shadow group">
          <div class="w-12 h-12 rounded-xl bg-brand-700/10 flex items-center justify-center mb-6 group-hover:bg-brand-700 transition-colors">
            <svg class="w-6 h-6 text-brand-700 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Instant Feedback</h3>
          <p class="text-slate-500 text-sm leading-relaxed">
            Results in seconds. Save valuable administrative time and reduce rework — so you can focus on what matters most: your clients' progress and outcomes.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────────────────────
       HOW IT WORKS
  ───────────────────────────────────────────────────────────── -->
  <section id="how-it-works" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-700">How it Works</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
          Up and running in 3 simple steps
        </h2>
        <p class="mt-4 text-slate-500 max-w-xl mx-auto text-lg">
          No complex setup. No learning curve. Just install and start writing better notes.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connector line (desktop) -->
        <div class="hidden md:block absolute top-10 left-1/3 right-1/3 h-0.5 bg-linear-to-r from-brand-700/30 to-brand-500/30 translate-x-0"></div>

        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center">
          <div class="relative z-10 w-20 h-20 rounded-2xl bg-linear-to-br from-brand-700 to-brand-500 flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            </svg>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-white border-2 border-brand-700 text-brand-700 text-xs font-bold flex items-center justify-center">1</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Install the Extension</h3>
          <p class="text-slate-500 text-sm leading-relaxed max-w-xs">
            Add Note Reviewer to Chrome from the Web Store with one click. No account required to get started.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center">
          <div class="relative z-10 w-20 h-20 rounded-2xl bg-linear-to-br from-brand-700 to-brand-500 flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
            </svg>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-white border-2 border-brand-700 text-brand-700 text-xs font-bold flex items-center justify-center">2</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Enter Your API Key</h3>
          <p class="text-slate-500 text-sm leading-relaxed max-w-xs">
            Connect your own AI API key. Your key stays in your browser — we never store or access it on our servers.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center">
          <div class="relative z-10 w-20 h-20 rounded-2xl bg-linear-to-br from-brand-700 to-brand-500 flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-white border-2 border-brand-700 text-brand-700 text-xs font-bold flex items-center justify-center">3</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">Review Your Notes</h3>
          <p class="text-slate-500 text-sm leading-relaxed max-w-xs">
            Open any clinical note, activate the side panel, and receive immediate AI-powered quality and compliance suggestions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────────────────────
       PRIVACY & TRUST
  ───────────────────────────────────────────────────────────── -->
  <section id="privacy" class="py-24 bg-slate-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="bg-linear-to-br from-brand-700 to-brand-600 rounded-3xl p-10 md:p-16 text-white relative overflow-hidden">
        <!-- decorative circle -->
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-white/5"></div>
        <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full bg-white/5"></div>

        <div class="relative grid md:grid-cols-2 gap-12 items-center">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest text-sky-300">Privacy &amp; Trust</span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight leading-snug">
              Your patients' data<br />stays private. Always.
            </h2>
            <p class="mt-5 text-white/75 text-lg leading-relaxed">
              Note Reviewer is built with privacy-first architecture. We process your notes securely and never store, log, or transmit any Protected Health Information (PHI).
            </p>
          </div>

          <div class="grid grid-cols-1 gap-4">
            <!-- Trust item -->
            {[
              { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', text: 'No PHI is ever stored on our servers' },
              { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', text: 'Your API key is stored locally in your browser only' },
              { icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', text: 'Data is encrypted in transit via HTTPS / TLS' },
              { icon: 'M10 21h7a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v11m0 5l4.879-4.879m0 0a3 3 0 104.243-4.242 3 3 0 00-4.243 4.242z', text: 'Original notes are never modified by the extension' },
            ].map(({ icon, text }) => (
              <div class="flex items-start gap-3 bg-white/10 rounded-xl px-5 py-4">
                <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icon}/>
                </svg>
                <span class="text-sm text-white/90 font-medium">{text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────────────────────────────────────
       CTA FINAL
  ───────────────────────────────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-5">
        Ready to elevate your<br class="hidden md:block" /> clinical documentation?
      </h2>
      <p class="text-slate-500 text-lg mb-10">
        Join ABA professionals who trust Note Reviewer for faster, higher-quality notes — every session.
      </p>
      <a
        href="https://chromewebstore.google.com"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 bg-brand-700 hover:bg-brand-800 text-white font-bold text-base px-10 py-4 rounded-xl transition-colors shadow-lg"
      >
        Get Started — It's Free
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ─────────────────────────────────────────────────────────
       FOOTER
  ───────────────────────────────────────────────────────────── -->
  <footer id="contact" class="bg-slate-900 text-slate-400 py-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-10 mb-10">

        <!-- Brand -->
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-brand-700 text-white font-bold text-sm">NR</span>
            <span class="font-semibold text-white text-sm">Note Reviewer</span>
          </div>
          <p class="text-sm leading-relaxed">
            AI-powered clinical note quality &amp; compliance for ABA professionals. A product by <span class="text-white font-medium">Infinity Code LLC</span>.
          </p>
        </div>

        <!-- Product -->
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">Product</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
            <li><a href="#how-it-works" class="hover:text-white transition-colors">How it Works</a></li>
            <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
            <li>
              <a href="https://chromewebstore.google.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">
                Chrome Web Store ↗
              </a>
            </li>
          </ul>
        </div>

        <!-- Support -->
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">Support</h4>
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href="mailto:info@notereviewer.org" class="hover:text-white transition-colors">info@notereviewer.org</a>
            </li>
            <li class="flex items-center gap-2">
              <!-- WhatsApp icon -->
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <a href="https://wa.me/13053079212" target="_blank" rel="noopener" class="hover:text-white transition-colors">+1 305-307-9212</a>
            </li>
          </ul>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs">
        <p>&copy; {new Date().getFullYear()} Infinity Code LLC. All rights reserved.</p>
        <p class="text-slate-600">Note Reviewer is not affiliated with any EHR provider.</p>
      </div>
    </div>
  </footer>
</Layout>
