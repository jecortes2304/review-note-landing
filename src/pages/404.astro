---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 – Page Not Found | Note Reviewer"
  description="The page you requested could not be found. Head back to Note Reviewer to explore features, install the extension, or review our privacy policy."
>
  <Navbar basePath="/" />

  <main class="relative overflow-hidden bg-linear-to-br from-brand-700 via-brand-600 to-brand-500 text-white">
    <div
      class="absolute inset-0 opacity-[0.08]"
      style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 30px 30px;"
    ></div>
    <div class="orb orb-1 absolute rounded-full pointer-events-none"></div>
    <div class="orb orb-2 absolute rounded-full pointer-events-none"></div>

    <section class="relative max-w-6xl mx-auto px-6 py-24 md:py-32 lg:py-36">
      <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-12 items-center">
        <div class="max-w-2xl">
          <span class="inline-flex items-center gap-2 bg-white/15 border border-white/20 text-white/90 text-xs font-semibold uppercase tracking-[0.24em] px-4 py-2 rounded-full mb-6">
            <span class="w-2 h-2 rounded-full bg-amber-300 animate-pulse"></span>
            Error 404
          </span>

          <div class="inline-flex items-center rounded-3xl border border-white/15 bg-white/10 px-5 py-3 mb-6 backdrop-blur-sm shadow-lg shadow-brand-900/20">
            <span class="text-5xl md:text-6xl font-black tracking-tight">404</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
            We couldn&apos;t find that page.
          </h1>

          <p class="mt-6 text-lg md:text-xl text-white/78 leading-relaxed max-w-xl">
            The link may be outdated, the page may have moved, or the URL might have been typed incorrectly.
            Let&apos;s get you back to something useful.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              href="/"
              class="inline-flex items-center justify-center gap-2 rounded-2xl bg-white text-brand-700 px-6 py-3.5 text-sm font-semibold shadow-lg shadow-brand-900/20 transition-transform hover:-translate-y-0.5 hover:text-brand-800"
            >
              Back to home
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <a
              href="/privacy"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/25 bg-white/10 px-6 py-3.5 text-sm font-semibold text-white/90 backdrop-blur-sm transition-colors hover:bg-white/15 hover:text-white"
            >
              View privacy policy
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h4m0 0v4m0-4l-8 8"/>
              </svg>
            </a>
          </div>

          <div class="mt-10 flex flex-wrap gap-3 text-sm text-white/70">
            <a href="/#features" class="rounded-full border border-white/15 bg-white/8 px-4 py-2 transition-colors hover:bg-white/14 hover:text-white">Features</a>
            <a href="/#how-it-works" class="rounded-full border border-white/15 bg-white/8 px-4 py-2 transition-colors hover:bg-white/14 hover:text-white">How it Works</a>
            <a href="/#install" class="rounded-full border border-white/15 bg-white/8 px-4 py-2 transition-colors hover:bg-white/14 hover:text-white">Install Extension</a>
            <a href="mailto:info@notereviewer.org" class="rounded-full border border-white/15 bg-white/8 px-4 py-2 transition-colors hover:bg-white/14 hover:text-white">Contact Support</a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-6 rounded-[2rem] bg-white/10 blur-3xl"></div>

          <div class="relative rounded-[2rem] border border-white/15 bg-white/10 p-6 md:p-7 backdrop-blur-xl shadow-2xl shadow-brand-900/25">
            <div class="flex items-center justify-between gap-4 border-b border-white/10 pb-5">
              <div>
                <p class="text-xs uppercase tracking-[0.22em] text-white/55">Suggested next steps</p>
                <h2 class="mt-2 text-2xl font-bold text-white">Keep exploring Note Reviewer</h2>
              </div>
              <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-white text-brand-700 shadow-lg">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2a4 4 0 014-4h8m0 0l-3-3m3 3l-3 3M5 3h8a2 2 0 012 2v4M5 21h8a2 2 0 002-2v-4"/>
                </svg>
              </div>
            </div>

            <div class="mt-6 space-y-4">
              {[
                {
                  title: 'See product highlights',
                  description: 'Review the core features built for clinical note quality and ABA compliance.',
                  href: '/#features',
                },
                {
                  title: 'Learn how setup works',
                  description: 'Get from install to note review in three simple steps.',
                  href: '/#how-it-works',
                },
                {
                  title: 'Check privacy details',
                  description: 'Understand how your API key and note content are handled.',
                  href: '/privacy',
                },
              ].map(({ title, description, href }, index) => (
                <a
                  href={href}
                  class="group flex items-start gap-4 rounded-2xl border border-white/10 bg-slate-950/15 px-4 py-4 transition-all hover:border-white/20 hover:bg-slate-950/25"
                >
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-white/12 text-sm font-bold text-white">
                    0{index + 1}
                  </span>
                  <span class="min-w-0 flex-1">
                    <span class="block text-sm font-semibold text-white group-hover:text-sky-100">{title}</span>
                    <span class="mt-1 block text-sm leading-relaxed text-white/65">{description}</span>
                  </span>
                  <svg class="mt-0.5 w-5 h-5 shrink-0 text-white/45 transition-transform group-hover:translate-x-0.5 group-hover:text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              ))}
            </div>

            <div class="mt-6 rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-4 py-4 text-sm text-emerald-50">
              <div class="flex items-start gap-3">
                <svg class="mt-0.5 w-5 h-5 shrink-0 text-emerald-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="leading-relaxed text-white/80">
                  Tip: if you typed the address manually, double-check the URL. Otherwise, head back home and continue from the main navigation.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .orb {
    filter: blur(90px);
    opacity: 0.35;
  }

  .orb-1 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(125, 211, 252, 0.75) 0%, transparent 70%);
    top: -140px;
    right: 4%;
  }

  .orb-2 {
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(167, 139, 250, 0.55) 0%, transparent 70%);
    bottom: -90px;
    left: 2%;
  }
</style>

